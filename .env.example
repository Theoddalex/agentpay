# Copy to .env and adjust.  cp .env.example .env

# --- Ethereum (Base Sepolia testnet — do NOT point at mainnet) ---
# Base Sepolia is the default: Circle's testnet USDC lives here (with a faucet)
# and it's where agent-payment activity concentrates. For Ethereum Sepolia
# instead, use RPC_URL=https://ethereum-sepolia-rpc.publicnode.com CHAIN_ID=11155111
# (USDC is a known token on both networks).
RPC_URL=https://sepolia.base.org
CHAIN_ID=84532
KEYSTORE_PATH=wallet.key

# --- Policy / audit ---
POLICY_PATH=policy.yaml
AUDIT_DB_PATH=audit.db

# --- Safety switch ---
# Writes (actual ETH transfers) are OFF by default. Set to true ONLY on testnet
# with a throwaway, faucet-funded key once you've verified policy behaviour.
ENABLE_SENDS=false

# --- Transport & auth ---
# stdio (default): local, the OS is the auth boundary; identity = AGENT_ID.
# streamable-http: hosted at http://HOST:PORT/mcp — REQUIRES API keys.
TRANSPORT=stdio
HOST=127.0.0.1
PORT=8000
AGENT_ID=local

# Hosted mode: comma-separated "key:agent_id" pairs. Clients authenticate with
# "Authorization: Bearer <key>"; the agent_id selects their policy + audit trail.
# Generate keys with e.g.:  python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENTMANDATE_API_KEYS=
# Admin keys ("key:admin_id,...") — human operators who may resolve
# needs_approval payments (list_pending_approvals / resolve_approval). Keep these
# separate from agent keys so an agent can never approve its own payment. Over
# stdio the local operator is admin automatically; this is for hosted mode.
AGENTMANDATE_ADMIN_KEYS=
# Explicit opt-out of auth for local experiments only. Never in production.
ALLOW_ANONYMOUS=false
